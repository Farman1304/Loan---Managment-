rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: This rule assumes admins are identified by a users/{uid}.role field.
    // In production, prefer custom claims for admin.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /loans/{loanId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Users can update their own loan only if still pending (e.g., fix description).
      allow update: if isAdmin() ||
        (isSignedIn() &&
          resource.data.userId == request.auth.uid &&
          resource.data.status == "pending" &&
          request.resource.data.status == "pending");

      allow delete: if isAdmin();
    }
  }
}

